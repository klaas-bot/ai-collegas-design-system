{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "AI Collega's design tokens — W3C Design Tokens Community Group format",

  "color": {
    "brand": {
      "orange": { "$value": "#f97316", "$type": "color", "$description": "Primary brand orange — gradient start" },
      "red":    { "$value": "#ef4444", "$type": "color", "$description": "Brand red — gradient mid" },
      "pink":   { "$value": "#ec4899", "$type": "color", "$description": "Brand pink — gradient end" }
    },
    "neutral": {
      "black":   { "$value": "#000000", "$type": "color" },
      "white":   { "$value": "#ffffff", "$type": "color" },
      "gray-50": { "$value": "#fafafa", "$type": "color" },
      "gray-100":{ "$value": "#f4f4f5", "$type": "color" },
      "gray-200":{ "$value": "#e4e4e7", "$type": "color" },
      "gray-400":{ "$value": "#a1a1aa", "$type": "color" },
      "gray-600":{ "$value": "#52525b", "$type": "color" },
      "gray-900":{ "$value": "#18181b", "$type": "color" }
    },
    "semantic": {
      "success": { "$value": "#10b981", "$type": "color" },
      "warning": { "$value": "#f59e0b", "$type": "color" },
      "danger":  { "$value": "#ef4444", "$type": "color" },
      "info":    { "$value": "#3b82f6", "$type": "color" }
    }
  },

  "gradient": {
    "brand-3": {
      "$value": "linear-gradient(90deg, #f97316 0%, #ef4444 50%, #ec4899 100%)",
      "$type": "gradient",
      "$description": "Signature 3-stop gradient (oranje → rood → roze) — voor tekst-accent en hero-elementen"
    },
    "brand-2": {
      "$value": "linear-gradient(90deg, #f97316 0%, #ef4444 100%)",
      "$type": "gradient",
      "$description": "2-stop gradient (oranje → rood) — voor backgrounds en pill-buttons"
    }
  },

  "typography": {
    "fontFamily": {
      "primary": {
        "$value": "Inter, 'Inter Fallback', system-ui, sans-serif",
        "$type": "fontFamily",
        "$description": "Inter is de primaire huisstijl-font van AI Collega's — zoals ingezet op aicollegas.nl. Laden via Google Fonts of @fontsource/inter."
      },
      "fallback": {
        "$value": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
        "$type": "fontFamily",
        "$description": "Fallback wanneer Inter niet beschikbaar is (bv. e-mail-clients)"
      }
    },
    "fontSize": {
      "xs":   { "$value": "12px", "$type": "dimension" },
      "sm":   { "$value": "14px", "$type": "dimension" },
      "base": { "$value": "16px", "$type": "dimension" },
      "lg":   { "$value": "18px", "$type": "dimension" },
      "xl":   { "$value": "20px", "$type": "dimension" },
      "2xl":  { "$value": "24px", "$type": "dimension" },
      "3xl":  { "$value": "32px", "$type": "dimension" },
      "4xl":  { "$value": "48px", "$type": "dimension" },
      "5xl":  { "$value": "64px", "$type": "dimension" },
      "logo": { "$value": "80px", "$type": "dimension", "$description": "AI / .NL logo grootte" }
    },
    "fontWeight": {
      "regular": { "$value": "400", "$type": "fontWeight" },
      "medium":  { "$value": "500", "$type": "fontWeight" },
      "bold":    { "$value": "700", "$type": "fontWeight" }
    },
    "lineHeight": {
      "tight":  { "$value": "1.2", "$type": "number" },
      "normal": { "$value": "1.5", "$type": "number" },
      "loose":  { "$value": "1.75", "$type": "number" }
    }
  },

  "spacing": {
    "0":  { "$value": "0px",  "$type": "dimension" },
    "1":  { "$value": "4px",  "$type": "dimension" },
    "2":  { "$value": "8px",  "$type": "dimension" },
    "3":  { "$value": "12px", "$type": "dimension" },
    "4":  { "$value": "16px", "$type": "dimension" },
    "6":  { "$value": "24px", "$type": "dimension" },
    "8":  { "$value": "32px", "$type": "dimension" },
    "12": { "$value": "48px", "$type": "dimension" },
    "16": { "$value": "64px", "$type": "dimension" },
    "24": { "$value": "96px", "$type": "dimension" }
  },

  "radius": {
    "none": { "$value": "0px",   "$type": "dimension" },
    "sm":   { "$value": "4px",   "$type": "dimension" },
    "md":   { "$value": "8px",   "$type": "dimension" },
    "lg":   { "$value": "16px",  "$type": "dimension" },
    "xl":   { "$value": "24px",  "$type": "dimension" },
    "pill": { "$value": "9999px","$type": "dimension", "$description": "Volledig afgeronde pill — voor CTAs en logo-rect" }
  },

  "shadow": {
    "sm": { "$value": "0 1px 2px 0 rgb(0 0 0 / 0.05)", "$type": "shadow" },
    "md": { "$value": "0 4px 6px -1px rgb(0 0 0 / 0.1)", "$type": "shadow" },
    "lg": { "$value": "0 10px 15px -3px rgb(0 0 0 / 0.1)", "$type": "shadow" },
    "xl": { "$value": "0 20px 25px -5px rgb(0 0 0 / 0.1)", "$type": "shadow" }
  }
}
